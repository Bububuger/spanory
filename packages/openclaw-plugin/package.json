{
  "name": "@bububuger/spanory-openclaw-plugin",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
