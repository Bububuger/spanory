{
  "name": "@alipay/spanory",
  "version": "0.1.33",
  "description": "Spanory CLI for cross-runtime agent observability",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.antgroup-inc.cn",
    "tag": "latest"
  },
  "files": [
    "dist",
    "openclaw-plugin",
    "opencode-plugin"
  ],
  "bin": {
    "spanory": "dist/index.js"
  },
  "scripts": {
    "check": "node -e \"console.log('alipay-cli:check:noop')\"",
    "build": "npm run prepare-js",
    "test": "node --test test/*.test.mjs",
    "prepare-js": "bash scripts/prepare-bin.sh",
    "prepare-bin": "bash scripts/prepare-bin.sh",
    "prepublishOnly": "npm run prepare-js"
  },
  "dependencies": {
    "commander": "^14.0.1"
  }
}
