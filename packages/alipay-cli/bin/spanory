#!/bin/sh
# Resolve symlinks to find the real directory of this script
target="$0"
while [ -L "$target" ]; do
  link="$(readlink "$target")"
  case "$link" in
    /*) target="$link" ;;
    *)  target="$(dirname "$target")/$link" ;;
  esac
done
DIR="$(cd "$(dirname "$target")" && pwd)"

OS="$(uname -s)"
ARCH="$(uname -m)"

if [ "$OS" = "Darwin" ] && [ "$ARCH" = "arm64" ]; then
  exec "$DIR/spanory-macos-arm64" "$@"
elif [ "$OS" = "Darwin" ]; then
  exec "$DIR/spanory-macos-x64" "$@"
elif [ "$OS" = "Linux" ] && [ "$ARCH" = "x86_64" ]; then
  exec "$DIR/spanory-linux-x64" "$@"
else
  echo "Unsupported platform: $OS-$ARCH" >&2
  exit 1
fi
