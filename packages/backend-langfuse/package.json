{
  "name": "@bububuger/backend-langfuse",
  "version": "0.1.35",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "check": "npm run build:deps && tsc -p tsconfig.json --noEmit",
    "build:deps": "npm run --workspace @bububuger/otlp-core build",
    "build": "npm run build:deps && node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs"
  }
}
