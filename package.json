{
  "name": "spanory",
  "private": true,
  "version": "0.1.28",
  "description": "Cross-runtime observability toolkit for agent systems",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "npm run --workspaces check",
    "build": "npm run --workspaces build",
    "test": "npm run --workspaces test",
    "test:bdd": "npm run --workspace @bububuger/spanory test:bdd",
    "telemetry:extract": "node scripts/telemetry/extract-spanory-fields.mjs",
    "telemetry:sync-otel-semconv": "node scripts/telemetry/sync-otel-semconv.mjs",
    "telemetry:diff": "node scripts/telemetry/diff-fields.mjs",
    "telemetry:validate-mapping": "node scripts/telemetry/validate-mapping.mjs",
    "telemetry:report": "node scripts/telemetry/report.mjs",
    "telemetry:check": "node scripts/telemetry/check.mjs",
    "issue:status": "node scripts/issues/status-report.mjs summary",
    "build:bin": "bash scripts/release/build-binaries.sh",
    "package:release-assets": "bash scripts/release/package-release-assets.sh",
    "version:sync": "node scripts/release/sync-version.mjs",
    "publish:internal": "bash scripts/publish-internal.sh"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "registry": "https://registry.antgroup-inc.cn"
  }
}
